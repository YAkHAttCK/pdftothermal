<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <header class="site-header wrapper">
    <a class="logo" href="/">PDF to Thermal</a>
    <nav>
      <a href="/faq">FAQ</a>
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="/contact">Contact</a>
    </nav>
  </header>

  <main class="wrapper section narrow">
    <div class="card result-card">
      <h1><%= success ? 'Conversion Complete' : 'Something Went Wrong' %></h1>
      <p><%= message %></p>

      <% if (downloadUrl) { %>
        <a class="btn" href="<%= downloadUrl %>" download>Download <%= outputFilename %></a>
      <% } %>

      <a class="btn btn-secondary" href="/">Convert another label</a>
    </div>
  </main>
</body>
</html>
